<Window x:Class="GakumasuCalc.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GakumasuCalc.ViewModels"
        xmlns:conv="clr-namespace:GakumasuCalc.Converters"
        Title="学マス 育成ステータス理論値計算ツール"
        Width="780" MinWidth="700" Height="950"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/favicon.ico">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:ActionTypeToStringConverter x:Key="ActionToStr"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>

            <!-- Title -->
            <TextBlock Text="学マス 育成ステータス理論値計算ツール"
                       FontSize="20" FontWeight="Bold" Foreground="#333"
                       Margin="0,0,0,16"/>

            <!-- 育成プラン選択 -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="育成プラン" Style="{StaticResource SectionHeader}"/>
                    <ComboBox ItemsSource="{Binding AvailablePlans}"
                              SelectedItem="{Binding SelectedPlan}"
                              DisplayMemberPath="Name"
                              FontSize="14" Padding="8,6" MinWidth="300"/>
                </StackPanel>
            </Border>

            <!-- 育成タイプ + 所持フィルタ -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="育成タイプ" Style="{StaticResource SectionHeader}"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding PlanTypeOptions}"
                                  SelectedValue="{Binding SelectedPlanType}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="DisplayName"
                                  FontSize="14" Padding="8,6" MinWidth="200"/>
                        <CheckBox Content="所持カードのみで計算" IsChecked="{Binding OwnedOnly}"
                                  FontSize="13" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 属性設定 -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="属性設定" Style="{StaticResource SectionHeader}"/>

                    <!-- ヘッダー -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="属性" FontSize="12" FontWeight="SemiBold" Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="メイン/サブ" FontSize="12" FontWeight="SemiBold" Foreground="#666"/>
                        <TextBlock Grid.Column="2" Text="SP枚数" FontSize="12" FontWeight="SemiBold" Foreground="#666"/>
                    </Grid>

                    <!-- Vocal -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Vocal" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource VoBrush}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding VoRole}"
                                  FontSize="12" Padding="6,4" Width="85" HorizontalAlignment="Left"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBox Text="{Binding VoSpCount, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                     Style="{StaticResource NumericTextBox}"
                                     Width="50" FontSize="14" Padding="6,4"
                                     HorizontalContentAlignment="Center"/>
                            <TextBlock Text="枚" FontSize="12" Foreground="#666"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Dance -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dance" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource DaBrush}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding DaRole}"
                                  FontSize="12" Padding="6,4" Width="85" HorizontalAlignment="Left"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBox Text="{Binding DaSpCount, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                     Style="{StaticResource NumericTextBox}"
                                     Width="50" FontSize="14" Padding="6,4"
                                     HorizontalContentAlignment="Center"/>
                            <TextBlock Text="枚" FontSize="12" Foreground="#666"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Visual -->
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Visual" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ViBrush}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding ViRole}"
                                  FontSize="12" Padding="6,4" Width="85" HorizontalAlignment="Left"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBox Text="{Binding ViSpCount, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                     Style="{StaticResource NumericTextBox}"
                                     Width="50" FontSize="14" Padding="6,4"
                                     HorizontalContentAlignment="Center"/>
                            <TextBlock Text="枚" FontSize="12" Foreground="#666"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- レッスン内イベント回数 -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="レッスン内イベント回数" Style="{StaticResource SectionHeader}" Margin="0"/>
                        <ComboBox ItemsSource="{Binding EventCountTemplates}"
                                  SelectedItem="{Binding SelectedEventTemplate}"
                                  FontSize="12" Padding="6,4" Width="180" Margin="16,0,0,0"
                                  VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <Expander Header="詳細を編集" IsExpanded="False" FontSize="12" Foreground="#666">
                    <WrapPanel Margin="0,8,0,0">
                        <!-- 列1: アイテム系 -->
                        <StackPanel Margin="0,0,24,0">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Pドリンク獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding PDrinkAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Pアイテム獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding PItemAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="スキル(SSR)獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SkillSsrAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="相談ドリンク交換" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ConsultationDrink, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- 列2: スキル操作系 -->
                        <StackPanel Margin="0,0,24,0">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="スキル強化" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SkillEnhance, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="スキル削除" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SkillDelete, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="スキルカスタム" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SkillCustom, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="スキルチェンジ" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SkillChange, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="アクティブ強化" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ActiveEnhance, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="アクティブ削除" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ActiveDelete, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="アクティブ獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ActiveAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="メンタル強化" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding MentalEnhance, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- 列3: カード種別獲得 -->
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="メンタル獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding MentalAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="元気カード獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding GenkiAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="好調カード獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding GoodConditionAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="好印象カード獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding GoodImpressionAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="温存カード獲得" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ConserveAcquire, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource NumericTextBox}"
                                         FontSize="12" Padding="4,3" HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </WrapPanel>
                    </Expander>
                </StackPanel>
            </Border>

            <!-- ボタン -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,12">
                <Button Content="計算実行" Command="{Binding CalculateCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>
                <Button Content="リセット" Command="{Binding ResetCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </StackPanel>

            <!-- 編成パターン比較 -->
            <ItemsControl ItemsSource="{Binding PatternResults}"
                          Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Label}" Style="{StaticResource SectionHeader}"
                                               FontSize="15" VerticalAlignment="Center" Margin="0"/>
                                    <Button Content="この編成で計算"
                                            Command="{Binding DataContext.SelectPatternCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Margin="12,0,0,0" Padding="10,4" FontSize="11"
                                            Cursor="Hand"/>
                                    <TextBlock Text="&#x2713; 選択中" FontSize="12" Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0"
                                               Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <!-- カード一覧ヘッダー -->
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="属性" FontSize="11" Foreground="#999"/>
                                    <TextBlock Grid.Column="1" Text="育成" FontSize="11" Foreground="#999"/>
                                    <TextBlock Grid.Column="2" Text="サポートカード" FontSize="11" Foreground="#999"/>
                                    <TextBlock Grid.Column="3" Text="ステータス値" FontSize="11" Foreground="#999"
                                               HorizontalAlignment="Right"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Cards}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4,5" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0"
                                                    Cursor="Help">
                                                <Border.ToolTip>
                                                    <ToolTip MaxWidth="500">
                                                        <TextBlock Text="{Binding BreakdownText}"
                                                                   FontFamily="Consolas" FontSize="11"
                                                                   TextWrapping="Wrap"/>
                                                    </ToolTip>
                                                </Border.ToolTip>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="30"/>
                                                        <ColumnDefinition Width="30"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#F0F0F0" CornerRadius="3"
                                                            Padding="4,2" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding CardTypeDisplay}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#555"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding CardPlanDisplay}"
                                                               FontSize="10" Foreground="#999"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding CardRarity}"
                                                               FontSize="10" Foreground="#888"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding CardName}"
                                                               FontSize="12" VerticalAlignment="Center"
                                                               Margin="4,0,0,0"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding StatValue, StringFormat=N0}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 合計 -->
                                <Border Margin="0,6,0,0" Padding="8,5" Background="#F5F5F5" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="合計" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat=N0}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ターン選択 -->
            <Border Style="{StaticResource SectionCard}"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="ターン選択" Style="{StaticResource SectionHeader}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="レッスン再計算" Command="{Binding RecalcLessonCommand}"
                                Style="{StaticResource SecondaryButton}" FontSize="11" Padding="12,4"/>
                    </StackPanel>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TurnChoices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding WeekLabel}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Foreground="#555"/>

                                                <!-- 固定イベント -->
                                                <TextBlock Grid.Column="1" Text="{Binding EventName}"
                                                           FontSize="12" Foreground="#999" FontStyle="Italic"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding IsFixedEvent, Converter={StaticResource BoolToVis}}"/>

                                                <!-- アクション選択 (ドロップダウン) -->
                                                <ComboBox Grid.Column="1"
                                                          ItemsSource="{Binding AvailableActions}"
                                                          SelectedItem="{Binding SelectedAction}"
                                                          FontSize="11" Padding="6,3" MinWidth="120"
                                                          Visibility="{Binding IsFixedEvent, Converter={StaticResource InverseBoolToVis}}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource ActionToStr}}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>



                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 計算結果 -->
            <Border Style="{StaticResource SectionCard}"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="計算結果" Style="{StaticResource SectionHeader}"/>

                    <!-- Vo -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Vo" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource VoBrush}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="24" CornerRadius="4"
                                Background="#F0F0F0" HorizontalAlignment="Left" Width="310">
                            <Border Background="{StaticResource VoBrush}"
                                    CornerRadius="4" HorizontalAlignment="Left"
                                    Width="{Binding VoBarWidth}"/>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding ResultVo, StringFormat=N0}"
                                   FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Da -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Da" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource DaBrush}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="24" CornerRadius="4"
                                Background="#F0F0F0" HorizontalAlignment="Left" Width="310">
                            <Border Background="{StaticResource DaBrush}"
                                    CornerRadius="4" HorizontalAlignment="Left"
                                    Width="{Binding DaBarWidth}"/>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding ResultDa, StringFormat=N0}"
                                   FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Vi -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Vi" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource ViBrush}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="24" CornerRadius="4"
                                Background="#F0F0F0" HorizontalAlignment="Left" Width="310">
                            <Border Background="{StaticResource ViBrush}"
                                    CornerRadius="4" HorizontalAlignment="Left"
                                    Width="{Binding ViBarWidth}"/>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding ResultVi, StringFormat=N0}"
                                   FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 合計 -->
                    <Border Margin="0,12,0,0" Padding="12,8" Background="#F5F5F5" CornerRadius="6">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="合計: " FontSize="18" Foreground="#666"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ResultTotal, StringFormat=N0}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                            <Button Content="📋 コピー" Command="{Binding CopyResultCommand}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    FontSize="11" Padding="8,4" Cursor="Hand"
                                    Background="#E0E0E0" BorderThickness="0"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
