<Window x:Class="CardInventoryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CardInventoryManager.ViewModels"
        Title="サポートカード所持管理" Width="963" Height="750"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5"
        Icon="/favicon_green.ico">

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
    </Window.InputBindings>

    <Window.DataContext>
        <vm:InventoryViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- ヘッダー -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="サポートカード所持管理" FontSize="20" FontWeight="Bold" Foreground="#333"/>
            <TextBlock FontSize="13" Foreground="#666" Margin="0,4,0,0">
                <Run Text="所持: "/><Run Text="{Binding OwnedCount, Mode=OneWay}"/>
                <Run Text=" / "/><Run Text="{Binding TotalCount, Mode=OneWay}"/><Run Text=" 枚"/>
                <Run Text="  (表示: "/><Run Text="{Binding FilteredCount, Mode=OneWay}"/><Run Text="枚)"/>
            </TextBlock>
        </StackPanel>

        <!-- フィルター + ボタン -->
        <Border DockPanel.Dock="Top" Background="White" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                    <TextBlock Text="検索" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Width="180" Padding="6,4" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                    <TextBlock Text="レア" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding RarityOptions}" SelectedItem="{Binding FilterRarity}"
                              Width="75" FontSize="12" Padding="4,3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                    <TextBlock Text="属性" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding FilterType}"
                              DisplayMemberPath="Display"
                              Width="75" FontSize="12" Padding="4,3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                    <TextBlock Text="所持" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding OwnedOptions}" SelectedItem="{Binding FilterOwned}"
                              Width="80" FontSize="12" Padding="4,3"/>
                </StackPanel>
                <Button Content="保存" Command="{Binding SaveCommand}"
                        Background="#5C6BC0" Foreground="White" FontSize="12"
                        Padding="16,6" Margin="0,0,8,4" Cursor="Hand"/>
                <Button Content="表示を全所持" Command="{Binding SelectAllCommand}"
                        FontSize="11" Padding="8,4" Margin="0,0,4,4" Cursor="Hand"/>
                <Button Content="表示を全未所持" Command="{Binding DeselectAllCommand}"
                        FontSize="11" Padding="8,4" Margin="0,0,0,4" Cursor="Hand"/>
            </WrapPanel>
        </Border>

        <!-- ステータスバー -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
                   FontSize="11" Foreground="#4CAF50" Margin="0,8,0,0"/>

        <!-- カード一覧 -->
        <Border Background="White" CornerRadius="6" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="140" Margin="4" Padding="6"
                                    Background="{Binding CardType, Converter={x:Static vm:CardTypeToBrushConverter.Instance}}"
                                    CornerRadius="6" Cursor="Hand"
                                    Opacity="{Binding OpacityValue}"
                                    BorderBrush="{Binding OwnedBorderBrush}"
                                    BorderThickness="{Binding OwnedBorderThickness}"
                                    MouseLeftButtonDown="Card_Click">
                                <!-- カード画像 -->
                                <StackPanel>
                                    <Border Height="100" CornerRadius="4" Background="#F8F8F8"
                                            Margin="0,0,0,4">
                                        <Image Source="{Binding ImagePath}"
                                               Stretch="Uniform" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <!-- カード情報 -->
                                    <TextBlock Text="{Binding CardName}" FontSize="10"
                                               TextTrimming="CharacterEllipsis" MaxHeight="28"
                                               TextWrapping="Wrap" Foreground="#333"
                                               ToolTip="{Binding CardName}"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Rarity}" FontSize="9"
                                                   FontWeight="Bold" Foreground="#666" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding TypeDisplay}" FontSize="9"
                                                   Foreground="#888" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding PlanDisplay}" FontSize="9"
                                                   Foreground="#AAA"/>
                                    </StackPanel>

                                    <!-- 所持 + 凸数 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <CheckBox IsChecked="{Binding Owned}" VerticalAlignment="Center"
                                                  Margin="0,0,4,0"/>
                                        <TextBlock Text="凸:" FontSize="10" Foreground="#666"
                                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <ComboBox ItemsSource="{Binding DataContext.UncapOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding Uncap}"
                                                  FontSize="10" Width="36" Padding="2,1"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
